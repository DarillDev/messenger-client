{
  "name": "messenger-client",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:mock-api": "concurrently \"ng serve --proxy-config proxy.conf.json\" \"npx ts-node -P tsconfig.mock-api.json src/mock-api/server.ts\"",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"src/**/*.scss\"",
    "lint:style:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,json}\""
  },
  "private": true,
  "packageManager": "npm@11.7.0",
  "dependencies": {
    "@angular-architects/ngrx-toolkit": "^21.0.1",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@ngrx/signals": "^21.1.0",
    "@ngrx/store": "^21.1.0",
    "@ngrx/store-devtools": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.1.2",
    "@angular/cli": "^21.1.2",
    "@angular/compiler-cli": "^21.1.0",
    "@jest/types": "^30.3.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.18",
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@types/jest": "^30.0.0",
    "@types/passport-jwt": "^4.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "stylelint": "^17.6.0",
    "stylelint-config-sass-guidelines": "^13.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.1"
  }
}
